---
import BaseLayout from '../layouts/BaseLayout.astro';
import { path } from '../utils/paths';
---
<BaseLayout title="Page not found — Saiful Islam Salim">
  <section class="wrap" style="padding:4rem 0">
    <p class="eyebrow">404</p>
    <h1>Page not found</h1>
    <p class="muted" style="margin-top:1rem">The page you're looking for doesn't exist or has moved.</p>
    <p style="margin-top:1.5rem"><a class="btn" href={path('/')}>Back to home</a></p>
  </section>
</BaseLayout>
